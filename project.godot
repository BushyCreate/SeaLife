config_version=5

[application]

config/name="SeaLife"
run/main_scene="uid://dcr33d44cbqnc"
config/features=PackedStringArray("4.6", "C#", "Forward Plus")
boot_splash/bg_color=Color(1, 1, 1, 1)
boot_splash/image="uid://cmps4nlqa67uo"
